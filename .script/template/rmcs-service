#! /bin/bash

set -e

RMCS_STOP_TIMEOUT_SECONDS=${RMCS_STOP_TIMEOUT_SECONDS:-10}
RMCS_PROCESS_PATTERN='host_sdk_sample|rmcs_executor|mavros_node|ros2 launch rmcs_bringup rmcs\.launch\.py'

start() {
    if [[ -z "$HOME" ]]; then
        export HOME=/root
    fi

    if is_running; then
        echo 'Error: RMCS daemon is still running!'
        exit 1
    fi

    source ~/env_setup.bash

    if [ -z "${RMCS_ROBOT_TYPE}" ]; then
        echo "Error: Please set robot type first (e.g. 'set-robot sentry')."
        exit 1
    fi

    screen -dmS rmcs bash -c "ros2 launch rmcs_bringup rmcs.launch.py robot:=${RMCS_ROBOT_TYPE}"

    sleep 0.1
    
    if is_running; then
        echo "Successfully started RMCS daemon."
    else
        echo "Error: Failed to start RMCS daemon."
        exit 1
    fi
}

attach() {
    screen -r rmcs
}

stop() {
    local stopped_screen=0

    if is_running; then
        screen -S rmcs -X quit
        stopped_screen=1
    fi

    wait_for_process_exit

    if (( stopped_screen )); then
        echo "Successfully stopped RMCS daemon."
    fi
}

wait_for_process_exit() {
    local waited=0

    while pgrep -f "$RMCS_PROCESS_PATTERN" >/dev/null; do
        if (( waited >= RMCS_STOP_TIMEOUT_SECONDS )); then
            echo "Error: Timed out waiting for RMCS processes to exit."
            echo "Still running:"
            pgrep -af "$RMCS_PROCESS_PATTERN" || true
            exit 1
        fi

        sleep 1
        waited=$((waited + 1))
    done
}

is_running() {
    if ls '/run/screen/S-root' 2>/dev/null | grep -q '.*\.rmcs'; then
        return 0
    else
        return 1
    fi
}

case "$1" in
    start)
        start
        ;;
    attach)
        attach
        ;;
    stop)
        stop
        ;;
    restart)
        stop
        start
        ;;
    *)
        echo 'Usage: service rmcs {start|attach|stop|restart}'
        exit 1
        ;;
esac

exit 0
