    <!-- END LINKS -->

    <joint name="${prefix}omni_infantry_base" type="fixed">
      <xacro:insert_block name="origin" />
      <parent link="${parent}" />
      <child link="${prefix}omni_infantry" />
    </joint>

    <joint name="${prefix}front_left_wheel" type="continuous">
      <origin
        xyz="0.16717772074203 0.167177720742029 -0.0906999999999999"
        rpy="0 0 0.785398163397448" />
      <parent link="${prefix}omni_infantry" />
      <child link="${prefix}front_left_wheel_link" />
      <axis xyz="1 0 0" />
    </joint>

    <joint name="${prefix}front_right_wheel" type="continuous">
      <origin
        xyz="0.16717772074203 -0.167177720742029 -0.0909700000000002"
        rpy="0 0 -0.785398163397448" />
      <parent link="${prefix}omni_infantry" />
      <child link="${prefix}front_right_wheel_link" />
      <axis xyz="1 0 0" />
    </joint>

    <joint name="${prefix}back_left_wheel" type="continuous">
      <origin
        xyz="-0.167177720742029 0.167177720742029 -0.0909700000000001"
        rpy="0 0 2.35619449019234" />
      <parent link="${prefix}omni_infantry" />
      <child link="${prefix}back_left_wheel_link" />
      <axis xyz="-1 0 0" />
    </joint>

    <joint name="${prefix}back_right_wheel" type="continuous">
      <origin
        xyz="-0.16717772074203 -0.16717772074203 -0.0907"
        rpy="0 0 -2.35619449019235" />
      <parent link="${prefix}omni_infantry" />
      <child link="${prefix}back_right_wheel_link" />
      <axis xyz="-1 0 0" />
    </joint>

    <joint name="${prefix}yaw" type="continuous">
      <origin
        xyz="0 0 0.1136"
        rpy="0 0 0.58626" />
      <parent link="${prefix}omni_infantry" />
      <child link="${prefix}yaw_link" />
      <axis xyz="0 0 -1" />
    </joint>

    <joint name="${prefix}pitch" type="revolute">
      <origin
        xyz="0 0 0.0934"
        rpy="0 -0.25743 0" />
      <parent link="${prefix}yaw_link" />
      <child link="${prefix}pitch_link" />
      <axis xyz="0 -1 0" />
      <limit
        lower="-1"
        upper="0.7"
        effort="0"
        velocity="0" />
    </joint>

    <joint name="${prefix}left_launch" type="continuous">
      <origin
        xyz="0.013 0.03625 0.0107"
        rpy="0 0 0" />
      <parent link="${prefix}pitch_link" />
      <child link="${prefix}left_launch_link" />
      <axis xyz="0 0 -1" />
    </joint>

    <joint name="${prefix}right_launch" type="continuous">
      <origin
        xyz="0.013 -0.03625 0.0107"
        rpy="0 0 0" />
      <parent link="${prefix}pitch_link" />
      <child link="${prefix}right_launch_link" />
      <axis xyz="0 0 -1" />
    </joint>

  </xacro:macro>
</robot>