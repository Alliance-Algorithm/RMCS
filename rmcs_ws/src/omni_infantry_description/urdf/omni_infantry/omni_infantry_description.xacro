          rpy="0 0 0" />
        <mass
          value="0.533176182602155" />
        <inertia
          ixx="0.00156014015731673"
          ixy="-5.42101086242752E-20"
          ixz="-2.99471370445972E-20"
          iyy="0.000817436842789066"
          iyz="8.52095872708936E-20"
          izz="0.000817436842789066" />
      </inertial>
      <visual>
