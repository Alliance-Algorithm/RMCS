    <link name="${prefix}right_launch_link">
      <inertial>
        <origin
          xyz="2.77555756156289E-17 1.73472347597681E-18 -0.00484999999999991"
          rpy="0 0 0" />
        <mass value="0.0265195187658292" />
        <inertia
          ixx="5.9775879282138E-06"
          ixy="-3.76709637678514E-22"
          ixz="1.05879118406788E-22"
          iyy="5.97758792821379E-06"
          iyz="1.4929471988187E-22"
          izz="1.15393056029814E-05" />
      </inertial>
      <visual>
        <origin
          xyz="0 0 0"
          rpy="0 0 0" />
        <geometry>
          <mesh filename="package://omni_infantry_description/meshes/right_launch_link.STL" />
        </geometry>
        <material name="">
          <color rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
        </material>
      </visual>
      <collision>
        <origin
          xyz="0 0 0"
          rpy="0 0 0" />
        <geometry>
          <mesh filename="package://omni_infantry_description/meshes/right_launch_link.STL" />
