<?xml version="1.0" encoding="UTF-8"?>
<robot xmlns:xacro="http://wiki.ros.org/xacro">

  <xacro:include filename="$(find omni_infantry_description)/urdf/common.xacro" />

  <xacro:macro name="omni_infantry" params="prefix parent *origin">
    <!-- LINKS -->
    <link name="${prefix}omni_infantry">
      <inertial>
        <origin
          xyz="-0.014464583145287 -3.47778019611777E-08 -0.0463018865662903"
          rpy="0 0 0" />
        <mass value="7.38762341423434" />
        <inertia
          ixx="0.0858099715349203"
          ixy="9.06674283545546E-08"
          ixz="0.00463615934367856"
          iyy="0.108320017042519"
          iyz="9.21827441556145E-06"
          izz="0.161187478867477" />
      </inertial>
      <visual>
        <origin
          xyz="0 0 0"
          rpy="-1.570796326794896 0 0" />
        <geometry>
          <mesh filename="package://omni_infantry_description/meshes/omni_infantry.STL" />
        </geometry>
        <material name="">
          <color rgba="0.792156862745098 0.819607843137255 0.933333333333333 1" />
        </material>
