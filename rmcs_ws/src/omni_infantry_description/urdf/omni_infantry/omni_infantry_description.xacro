    <link name="${prefix}left_launch_link">
      <inertial>
        <origin
          xyz="-2.77555756156289E-17 6.93889390390723E-18 -0.00484999999999991"
          rpy="0 0 0" />
        <mass value="0.0265195187658292" />
        <inertia
          ixx="5.9775879282138E-06"
          ixy="-4.67165284815436E-22"
          ixz="6.35274710440725E-22"
          iyy="5.97758792821379E-06"
